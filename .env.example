# ******************************************************************************* 
# Peppermint Helpdesk - Infrastructure Environment Template
# ------------------------------------------------------------------------------
# Reviewer Notes: 
# This file defines the necessary environmental injection points for the 
# containerized deployment. Values below are placeholders; real production 
# credentials must be managed via a vault or secure local environment.
# *******************************************************************************
# --- PostgreSQL Database Layer ---
# Ensure these credentials match the setup in the Docker volume initialization.
DB_USER=peppermint_admin
DB_PASSWORD=generate_strong_password_here
DB_NAME=peppermint_prod

# --- Security & Session Tokens ---
# SECRET_KEY: Used for signing session cookies
SECRET_KEY=generate_long_random_string_here

# --- Application Runtime ---
# Set to 'production' for live environments to ensure optimization
NODE_ENV=production
